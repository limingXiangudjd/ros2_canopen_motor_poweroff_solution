# ros2_controllers.yaml 示例
# 配置 controller_manager 和控制器

controller_manager:
  ros__parameters:
    update_rate: 100  # Hz

    # 控制器列表
    controllers:
      - velocity_controller
      - position_controller
      - joint_state_broadcaster

    # 切换控制器时的严格性
    switch_controller:
      strictness: best_effort

velocity_controller:
  ros__parameters:
    type: forward_command_controller/ForwardCommandController
    joints:
      - motor_joint
    interface_name: velocity

position_controller:
  ros__parameters:
    type: forward_command_controller/ForwardCommandController
    joints:
      - motor_joint
    interface_name: position

joint_state_broadcaster:
  ros__parameters:
    type: joint_state_broadcaster/JointStateBroadcaster
